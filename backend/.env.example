# ============================================================
# Hephaestus Live Agent — Environment Variables
# Copy this file to .env and fill in your values
# Get your Gemini API key: https://makersuite.google.com/app/apikey
# ============================================================

# --- Required ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Gemini Model (optional)
# Must support the Live API (bidiGenerateContent).
# Default: gemini-2.0-flash-live-001
GEMINI_MODEL=gemini-2.0-flash-live-001

# --- Server (optional) ---
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# --- CORS Origins (optional, comma-separated) ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- WebSocket (optional) ---
WS_PING_INTERVAL=20
WS_PING_TIMEOUT=20
WS_MAX_SIZE=10485760

# --- Frame Processing (optional) ---
FRAME_MAX_WIDTH=1280
FRAME_MAX_HEIGHT=720
FRAME_QUALITY=0.7

# --- Rate Limiting (optional) ---
RATE_LIMIT_MESSAGES=60
RATE_LIMIT_IMAGES=20
